```json
{
  "run_id": "2026-07-10_1432_a1b2",
  "pipeline": "full-auto",
  "autonomy": "full",
  "isolation": "worktree",
  "requirement": "为 App 增加离线缓存……",
  "worktree": { "path": "../myapp-aiflow-a1b2", "branch": "aiflow/a1b2" },
  "stages": [
    { "id": "brainstorm",  "status": "done", "artifact": "brainstorm-report.md" },
    { "id": "spec",        "status": "done" },
    { "id": "confirm-spec","status": "done" },
